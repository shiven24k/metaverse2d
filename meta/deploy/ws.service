[Unit]
Description=Metaverse 2D WebSocket Server
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/opt/metaverse2d/meta/apps/ws
EnvironmentFile=/opt/metaverse2d/meta/apps/ws/.env
ExecStart=/usr/bin/node --env-file=.env dist/index.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
